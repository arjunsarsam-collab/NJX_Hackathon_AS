{
  "manifest_version": 3,
  "name": "SafeCircle Gmail Guard",
  "version": "0.1.0",
  "description": "Flags suspicious Gmail messages before they are opened using simple yellow and red warnings.",
  "permissions": ["storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "action": {
    "default_title": "SafeCircle Gmail Guard",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["scoring.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}